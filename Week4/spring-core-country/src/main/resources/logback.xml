<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration.

  This assignment uses a plain ClassPathXmlApplicationContext instead of
  SpringApplication.run(), so Spring Boot's application.properties logging
  levels are NOT applied. This file sets the log levels directly so the DEBUG
  messages inside the Country constructor / getters / setters are printed.
-->
<configuration>

	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
		</encoder>
	</appender>

	<!-- Application code logs at DEBUG so constructor/getter/setter logs show. -->
	<logger name="com.cognizant.springlearn" level="DEBUG" />

	<!-- Keep Spring framework internals quiet at INFO. -->
	<root level="INFO">
		<appender-ref ref="CONSOLE" />
	</root>

</configuration>
